---
// HeroSection component - Full-width hero with overlay text and multi-image grid
import { puppies } from '../data/puppies';
const heroPuppies = puppies.filter(p => p.status === 'Available').slice(0, 6);
---

<section class="hero">
  <div class="hero-main">
    <div class="hero-bg">
      <img src={heroPuppies[0]?.image || '/images/puppies/COPPER male 10 weeks.jpeg'} alt="Dachshund puppy from Dapper Doxie" />
      <div class="hero-overlay"></div>
    </div>

    <div class="hero-container">
      <div class="hero-content">
        <span class="hero-badge">Dapper Doxie — Family Breeders Since 1995</span>
        <h1 class="hero-title">Dachshund Puppies<br><span class="highlight">Raised with Love</span></h1>
        <p class="hero-description">Family-raised Dachshund puppies in the heart of America. Health guaranteed, vet-checked, and ready to steal your heart.</p>
        <div class="hero-actions">
          <a href="/available-puppies" class="btn-primary">See Available Puppies</a>
          <a href="/contact" class="btn-secondary">Contact Us</a>
        </div>
      </div>

      <div class="hero-gallery">
        {heroPuppies.map((puppy, i) => (
          <div class={`gallery-card card-${i + 1}`}>
            <img src={puppy.image} alt={puppy.name} />
            <span class="gallery-label">{puppy.name}</span>
          </div>
        ))}
      </div>
    </div>
  </div>

  <div class="trust-bar">
    <div class="trust-container">
      <div class="trust-item">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
        <span>Family Raised</span>
      </div>
      <div class="trust-divider"></div>
      <div class="trust-item">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
        <span>Health Guaranteed</span>
      </div>
      <div class="trust-divider"></div>
      <div class="trust-item">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-5 14H7v-2h7v2zm3-4H7v-2h10v2zm0-4H7V7h10v2z"/></svg>
        <span>Vet Checked</span>
      </div>
      <div class="trust-divider"></div>
      <div class="trust-item">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm-2 16l-4-4 1.41-1.41L10 14.17l6.59-6.59L18 9l-8 8z"/></svg>
        <span>Lifetime Support</span>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    display: block;
    font-family: var(--font-family, 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif);
    overflow: hidden;
    padding: 0;
  }

  .hero-main {
    position: relative;
    min-height: 480px;
  }

  .hero-bg {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
  }

  .hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
  }

  .hero-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(135deg, rgba(20, 53, 33, 0.92) 0%, rgba(31, 81, 50, 0.8) 50%, rgba(46, 107, 69, 0.6) 100%);
  }

  .hero-container {
    position: relative;
    z-index: 1;
    max-width: 1200px;
    margin: 0 auto;
    padding: 1.5rem 2rem 3rem;
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: 3rem;
  }

  .hero-content {
    max-width: 560px;
  }

  .hero-badge {
    display: inline-block;
    background: rgba(255, 255, 255, 0.15);
    border: 1px solid rgba(255, 255, 255, 0.25);
    color: white;
    padding: 0.4rem 1rem;
    border-radius: 3px;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.8px;
    margin-bottom: 1.25rem;
    backdrop-filter: blur(8px);
  }

  .hero-title {
    font-size: 3.25rem;
    font-weight: 900;
    line-height: 1.1;
    color: white;
    margin: 0 0 1.25rem;
    letter-spacing: -0.5px;
  }

  .highlight {
    color: #4A8A63;
  }

  .hero-description {
    font-size: 1.05rem;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.85);
    margin: 0 0 1.75rem;
  }

  .hero-actions {
    display: flex;
    gap: 0.75rem;
  }

  .btn-primary {
    display: inline-flex;
    align-items: center;
    background: white;
    color: #1F5132;
    padding: 0.85rem 2rem;
    border-radius: 4px;
    font-size: 0.9rem;
    font-weight: 700;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    transition: all 0.3s ease;
  }

  .btn-primary:hover {
    background: #4A8A63;
    color: white;
    transform: translateY(-2px);
  }

  .btn-secondary {
    display: inline-flex;
    align-items: center;
    background: transparent;
    color: white;
    padding: 0.85rem 2rem;
    border-radius: 4px;
    border: 2px solid rgba(255, 255, 255, 0.4);
    font-size: 0.9rem;
    font-weight: 700;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    transition: all 0.3s ease;
  }

  .btn-secondary:hover {
    border-color: white;
    background: rgba(255, 255, 255, 0.1);
    color: white;
    transform: translateY(-2px);
  }

  .hero-gallery {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    width: 340px;
    justify-content: flex-end;
  }

  .gallery-card {
    position: relative;
    height: 130px;
    border-radius: 4px;
    overflow: hidden;
    border: 2px solid rgba(255, 255, 255, 0.2);
    transition: all 0.3s ease;
  }

  .gallery-card:hover {
    border-color: #4A8A63;
    transform: scale(1.03);
  }

  .card-1 { width: 55%; }
  .card-2 { width: 40%; }
  .card-3 { width: 38%; }
  .card-4 { width: 57%; }
  .card-5 { width: 48%; }
  .card-6 { width: 47%; }

  .gallery-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .gallery-label {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: linear-gradient(transparent, rgba(20, 53, 33, 0.85));
    color: white;
    padding: 1.5rem 0.6rem 0.4rem;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .trust-bar {
    background: #1F5132;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .trust-container {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 2rem;
    padding: 1rem 1.5rem;
  }

  .trust-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: rgba(255, 255, 255, 0.9);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.2px;
  }

  .trust-item svg {
    width: 18px;
    height: 18px;
    color: #4A8A63;
    flex-shrink: 0;
  }

  .trust-divider {
    width: 1px;
    height: 20px;
    background: rgba(255, 255, 255, 0.2);
  }

  @media (max-width: 900px) {
    .hero-main {
      min-height: auto;
    }

    .hero-container {
      grid-template-columns: 1fr;
      padding: 3rem 1.5rem 2.5rem;
      gap: 2rem;
    }

    .hero-content {
      text-align: center;
      max-width: 100%;
    }

    .hero-title {
      font-size: 2.5rem;
    }

    .hero-actions {
      justify-content: center;
    }

    .hero-gallery {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      width: 100%;
      max-width: 450px;
      margin: 0 auto;
      gap: 0.5rem;
    }

    .gallery-card {
      width: 100% !important;
      height: 150px;
    }

    .trust-container {
      flex-wrap: wrap;
      gap: 1rem;
    }

    .trust-divider {
      display: none;
    }
  }

  @media (max-width: 480px) {
    .hero-container {
      padding: 2.5rem 1rem 2rem;
    }

    .hero-badge {
      font-size: 0.65rem;
      padding: 0.3rem 0.75rem;
    }

    .hero-title {
      font-size: 2rem;
    }

    .hero-description {
      font-size: 0.95rem;
    }

    .hero-actions {
      flex-direction: column;
      align-items: center;
    }

    .hero-gallery {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      width: 100% !important;
      gap: 0.4rem;
    }

    .gallery-card {
      width: 100% !important;
      height: 130px;
    }

    .gallery-label {
      font-size: 0.6rem;
      padding: 1rem 0.4rem 0.3rem;
    }

    .trust-container {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 0.6rem;
      padding: 0.75rem 1rem;
    }

    .trust-item {
      font-size: 0.7rem;
    }

    .trust-item svg {
      width: 15px;
      height: 15px;
    }
  }
</style>
