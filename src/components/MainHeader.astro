---
// MainHeader component - Main navigation
---

<header class="header">
  <div class="header-container">
    <a href="/" class="logo">
      <img src="/images/logo.png" alt="Doxie Pups Creek logo" class="logo-img" />
      <span class="sr-only">Doxie Pups Creek</span>
    </a>

    <button class="menu-toggle" aria-label="Open menu" aria-expanded="false">
      <span></span>
      <span></span>
      <span></span>
    </button>

    <div class="nav-overlay"></div>

    <nav class="nav-menu">
      <div class="nav-brand-mobile">
        <span style="font-size: 1.1rem; font-weight: 700; color: #5C3D2E;">Doxie Pups Creek</span>
      </div>
      <ul>
        <li><a href="/">Home</a></li>
        <li><a href="/available-puppies">Available Puppies</a></li>
        <li><a href="/about">About Us</a></li>
        <li><a href="/parents">Parents</a></li>
        <li><a href="/testimonials">Testimonials</a></li>
        <li class="more-info-item">
          <button class="more-info-trigger" type="button" aria-expanded="false">
            More Info
            <svg class="more-info-icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"></path>
            </svg>
          </button>
          <ul class="more-info-menu">
            <li><a href="/contact">Contact Us</a></li>
            <li><a href="/faq">FAQ</a></li>
            <li><a href="/health-guarantee">Health Guarantee</a></li>
            <li><a href="/vaccinations">Vaccinations</a></li>
            <li><a href="/shipping">Shipping & Delivery</a></li>
            <li><a href="/sales-agreement">Sales Agreement</a></li>
            <li><a href="/about-the-breed">About the Breed</a></li>
            <li><a href="/basic-care">Basic Care Guide</a></li>
            <li><a href="/books">Recommended Books</a></li>
            <li><a href="/privacy-policy">Privacy Policy</a></li>
            <li><a href="/terms-of-service">Terms of Service</a></li>
            <li><a href="/return-refund-policy">Return & Refund Policy</a></li>
          </ul>
        </li>
      </ul>
      <a href="/contact" class="nav-cta-mobile">Adopt a Puppy</a>
    </nav>

    <a href="/contact" class="header-cta">Adopt a Puppy</a>
  </div>
</header>

<script>
  const menuToggle = document.querySelector('.menu-toggle');
  const nav = document.querySelector('.nav-menu');
  const overlay = document.querySelector('.nav-overlay');
  const moreInfoItem = document.querySelector('.more-info-item');
  const moreInfoTrigger = document.querySelector('.more-info-trigger');
  const navLinks = document.querySelectorAll('.nav-menu a');

  let isMenuOpen = false;

  const closeMenu = () => {
    isMenuOpen = false;
    nav?.classList.remove('active');
    overlay?.classList.remove('active');
    menuToggle?.classList.remove('active');
    menuToggle?.setAttribute('aria-expanded', 'false');
    moreInfoItem?.classList.remove('open');
    moreInfoTrigger?.setAttribute('aria-expanded', 'false');
  };

  menuToggle?.addEventListener('click', () => {
    isMenuOpen = !isMenuOpen;
    nav?.classList.toggle('active', isMenuOpen);
    overlay?.classList.toggle('active', isMenuOpen);
    menuToggle?.classList.toggle('active', isMenuOpen);
    menuToggle?.setAttribute('aria-expanded', String(isMenuOpen));

    if (!isMenuOpen) {
      moreInfoItem?.classList.remove('open');
      moreInfoTrigger?.setAttribute('aria-expanded', 'false');
    }
  });

  overlay?.addEventListener('click', closeMenu);

  moreInfoTrigger?.addEventListener('click', (event) => {
    event.preventDefault();
    const isOpen = moreInfoItem?.classList.toggle('open');
    moreInfoTrigger?.setAttribute('aria-expanded', String(Boolean(isOpen)));
  });

  document.addEventListener('click', (event) => {
    const target = event.target;
    if (!(target instanceof Node)) return;
    if (!moreInfoItem?.contains(target)) {
      moreInfoItem?.classList.remove('open');
      moreInfoTrigger?.setAttribute('aria-expanded', 'false');
    }
  });

  navLinks.forEach((link) => {
    link.addEventListener('click', () => {
      if (window.innerWidth <= 900) {
        closeMenu();
      }
    });
  });
</script>

<style>
  .header {
    display: block;
    font-family: var(--font-family, 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif);
    background: #FFF8F0;
    border-bottom: none;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    position: sticky;
    top: 0;
    z-index: 100;
    width: 100%;
  }

  .header-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0.875rem 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    flex-shrink: 0;
  }

  .logo-img {
    display: block;
    height: 52px;
    width: auto;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .nav-menu {
    display: flex;
    align-items: center;
    flex: 1;
    justify-content: center;
  }

  .nav-brand-mobile {
    display: none;
    font-size: 1.35rem;
    margin-bottom: 1.5rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid #eee;
  }

  .nav-cta-mobile {
    display: none;
  }

  .nav-menu > ul {
    display: flex;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: 2rem;
  }

  .nav-menu > ul > li {
    position: relative;
  }

  .nav-menu a,
  .more-info-trigger {
    text-decoration: none;
    color: #4a4a4a;
    font-weight: 500;
    font-size: 0.95rem;
    letter-spacing: 0.2px;
    transition: color 0.3s ease;
    position: relative;
    padding: 0.5rem 0;
  }

  .more-info-trigger {
    border: none;
    background: transparent;
    font-family: inherit;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
  }

  .more-info-icon {
    width: 14px;
    height: 14px;
    transition: transform 0.25s ease;
  }

  .nav-menu > ul > li > a::after,
  .more-info-trigger::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 2px;
    background: linear-gradient(90deg, #5C3D2E, #D4A574);
    transition: width 0.3s ease;
    border-radius: 1px;
  }

  .nav-menu a:hover {
    color: #5C3D2E;
  }

  .more-info-trigger:hover {
    color: #5C3D2E;
  }

  .nav-menu > ul > li > a:hover::after,
  .more-info-trigger:hover::after {
    width: 100%;
  }

  .more-info-item.open .more-info-icon,
  .more-info-item:hover .more-info-icon {
    transform: rotate(180deg);
  }

  .more-info-menu {
    list-style: none;
    margin: 0;
    padding: 0.45rem;
    position: absolute;
    right: 0;
    top: calc(100% + 0.55rem);
    min-width: 250px;
    background: #fff;
    border: 1px solid #eadfd4;
    border-radius: 12px;
    box-shadow: 0 14px 30px rgba(0, 0, 0, 0.12);
    opacity: 0;
    visibility: hidden;
    transform: translateY(8px);
    pointer-events: none;
    transition: opacity 0.2s ease, transform 0.2s ease, visibility 0.2s ease;
    z-index: 120;
  }

  .more-info-menu li {
    margin: 0;
  }

  .more-info-menu a {
    display: block;
    padding: 0.55rem 0.65rem;
    border-radius: 8px;
    font-size: 0.9rem;
    color: #4a4a4a;
  }

  .more-info-menu a:hover {
    background: #fff8f0;
    color: #5C3D2E;
  }

  .more-info-item:hover .more-info-menu,
  .more-info-item.open .more-info-menu {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
    pointer-events: auto;
  }

  .header-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #5C3D2E, #D4A574);
    color: white;
    padding: 0.7rem 1.5rem;
    border-radius: 50px;
    font-size: 0.9rem;
    font-weight: 600;
    text-decoration: none;
    letter-spacing: 0.3px;
    transition: all 0.3s ease;
    flex-shrink: 0;
    white-space: nowrap;
    box-shadow: 0 2px 10px rgba(92, 61, 46, 0.2);
  }

  .header-cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 15px rgba(92, 61, 46, 0.3);
    color: white;
  }

  .menu-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    padding: 0.5rem;
    background: none;
    border: none;
    cursor: pointer;
    z-index: 101;
  }

  .menu-toggle span {
    display: block;
    width: 24px;
    height: 2.5px;
    background: #5C3D2E;
    border-radius: 3px;
    transition: all 0.3s ease;
  }

  .menu-toggle.active span:nth-child(1) {
    transform: rotate(45deg) translate(5px, 5px);
  }

  .menu-toggle.active span:nth-child(2) {
    opacity: 0;
  }

  .menu-toggle.active span:nth-child(3) {
    transform: rotate(-45deg) translate(6px, -6px);
  }

  .nav-overlay {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.4);
    z-index: 98;
    backdrop-filter: blur(2px);
  }

  .nav-overlay.active {
    display: block;
  }

  @media (max-width: 1100px) {
    .nav-menu > ul {
      gap: 1.5rem;
    }

    .header-container {
      gap: 1.5rem;
    }
  }

  @media (max-width: 900px) {
    .menu-toggle {
      display: flex;
    }

    .header-container {
      padding: 0.875rem 1.5rem;
    }

    .nav-menu {
      position: fixed;
      top: 0;
      right: -100%;
      width: 300px;
      height: 100vh;
      background: white;
      flex-direction: column;
      padding: 2rem;
      box-shadow: -5px 0 30px rgba(0, 0, 0, 0.1);
      transition: right 0.3s ease;
      z-index: 99;
      justify-content: flex-start;
      align-items: flex-start;
    }

    .nav-menu.active {
      right: 0;
    }

    .nav-brand-mobile {
      display: block;
      width: 100%;
    }

    .nav-cta-mobile {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      background: linear-gradient(135deg, #5C3D2E, #D4A574);
      color: white;
      padding: 0.75rem 1.5rem;
      border-radius: 50px;
      font-size: 0.9rem;
      font-weight: 600;
      text-decoration: none;
      margin-top: 1.5rem;
      width: 100%;
      text-align: center;
    }

    .nav-menu > ul {
      flex-direction: column;
      gap: 0.25rem;
      width: 100%;
      padding: 0;
    }

    .nav-menu > ul > li {
      width: 100%;
    }

    .nav-menu > ul > li > a,
    .more-info-trigger {
      display: block;
      padding: 0.6rem 0;
      font-size: 0.95rem;
      width: 100%;
      text-align: left;
    }

    .more-info-trigger {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.5rem;
    }

    .nav-menu > ul > li > a::after,
    .more-info-trigger::after {
      display: none;
    }

    .more-info-menu {
      position: static;
      top: auto;
      right: auto;
      min-width: 100%;
      box-shadow: none;
      border-radius: 12px;
      border-color: #ece1d5;
      background: #fff8f0;
      margin: 0.2rem 0 0.5rem;
      opacity: 1;
      visibility: visible;
      transform: none;
      pointer-events: auto;
      display: none;
      padding: 0.55rem;
    }

    .more-info-item:hover .more-info-menu {
      display: none;
    }

    .more-info-item.open .more-info-menu {
      display: block;
    }

    .more-info-menu a {
      font-size: 0.9rem;
      padding: 0.68rem 0.78rem;
      min-height: 44px;
      display: flex;
      align-items: center;
      border: 1px solid #e6d9cd;
      background: #fff;
      border-radius: 10px;
      box-shadow: 0 1px 2px rgba(92, 61, 46, 0.06);
    }

    .more-info-menu li + li {
      margin-top: 0.42rem;
    }

    .more-info-menu a:hover,
    .more-info-menu a:focus-visible {
      background: #fff4e8;
      border-color: #d8bea6;
      color: #5C3D2E;
    }

    .more-info-item.open .more-info-icon {
      transform: rotate(180deg);
    }

    .header-cta {
      display: none;
    }
  }

  @media (max-width: 480px) {
    .header-container {
      padding: 0.75rem 1rem;
    }

    .logo-img {
      height: 38px;
    }
  }
</style>
