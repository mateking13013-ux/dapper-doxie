---
// FeaturedPuppies component - displays featured puppies
import { getFeaturedPuppies } from '../data/puppies';
const featuredPuppies = getFeaturedPuppies(5);
---

<section class="featured-section">
  <div class="section-header">
    <h2 class="section-title">
      Meet Our Puppies
      <span class="dog-icon">🐶</span>
    </h2>
    <p class="section-subtitle">Adorable Dachshund puppies looking for their forever homes</p>
  </div>

  <div class="puppies-container">
    <div class="puppies-grid">
      {featuredPuppies.map((puppy) => (
        <article class="puppy-card">
          <div class="card-image">
            <span class="variety-badge">{puppy.color}</span>
            <img src={puppy.image} alt={puppy.name} loading="lazy">
          </div>
          <div class="card-content">
            <h3 class="puppy-name">{puppy.name}</h3>
            <div class="card-stats">
              <span>Available</span>
              <span>Ready Now</span>
            </div>
            <a href="/contact" class="btn-contact">
              Inquire Now
            </a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .featured-section {
    display: block;
    font-family: var(--font-family, 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif);
    background: linear-gradient(135deg, #1F5132 0%, #143521 100%);
    padding: 3rem 1.5rem;
    position: relative;
  }

  .section-header {
    text-align: center;
    margin-bottom: 2rem;
  }

  .section-title {
    font-size: 2rem;
    font-weight: 700;
    color: white;
    margin: 0 0 0.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
  }

  .dog-icon {
    font-size: 1.5rem;
  }

  .section-subtitle {
    font-size: 1rem;
    color: rgba(255, 255, 255, 0.85);
    margin: 0;
    font-style: italic;
  }

  .puppies-container {
    max-width: 1400px;
    margin: 0 auto;
  }

  .puppies-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 1.25rem;
  }

  .puppy-card {
    background: white;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .puppy-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.15);
  }

  .card-image {
    position: relative;
    height: 220px;
    overflow: hidden;
    background: #f9f9f9;
    padding: 0.5rem;
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
    border-radius: 12px;
  }

  .variety-badge {
    position: absolute;
    top: 1rem;
    left: 1rem;
    background: #1F5132;
    color: white;
    padding: 0.3rem 0.6rem;
    border-radius: 6px;
    font-size: 0.75rem;
    font-weight: 600;
    z-index: 1;
  }

  .card-content {
    padding: 0.75rem 0.5rem;
    border-top: 2px dashed #eee;
  }

  .puppy-name {
    font-size: 1.1rem;
    font-weight: 700;
    color: #1F5132;
    margin: 0 0 0.5rem;
  }

  .card-stats {
    display: flex;
    justify-content: space-between;
    font-size: 0.75rem;
    color: #666;
    margin-bottom: 0.35rem;
  }

  .btn-contact {
    display: block;
    width: 100%;
    background: #1F5132;
    color: white;
    padding: 0.5rem;
    border: none;
    border-radius: 6px;
    font-size: 0.85rem;
    font-weight: 600;
    text-align: center;
    text-decoration: none;
    cursor: pointer;
    transition: background 0.3s ease;
  }

  .btn-contact:hover {
    background: #2E6B45;
  }

  @media (max-width: 1200px) {
    .puppies-grid {
      grid-template-columns: repeat(4, 1fr);
      gap: 1rem;
    }

    .puppy-card:nth-child(5) {
      display: none;
    }

    .card-image {
      height: 200px;
    }
  }

  @media (max-width: 900px) {
    .puppies-grid {
      grid-template-columns: repeat(3, 1fr);
    }

    .puppy-card:nth-child(4),
    .puppy-card:nth-child(5) {
      display: none;
    }

    .card-image {
      height: 220px;
    }
  }

  @media (max-width: 600px) {
    .featured-section {
      padding: 2rem 1rem;
    }

    .section-title {
      font-size: 1.5rem;
    }

    .puppies-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 0.75rem;
    }

    .puppy-card:nth-child(3),
    .puppy-card:nth-child(4),
    .puppy-card:nth-child(5) {
      display: none;
    }

    .card-image {
      height: 240px;
    }

    .card-content {
      padding: 1rem 0.75rem;
    }

    .puppy-name {
      font-size: 1rem;
    }
  }
</style>
