---
// PuppyCard Component - Available Puppies Page
interface Props {
  puppies: {
    name: string;
    breed: string;
    image: string;
    sex: string;
    age: string;
    color: string;
    status: string;
    price: number;
    description: string;
  }[];
}

const { puppies } = Astro.props;
---

<section class="puppies-section">
  <div class="container">
    {puppies.map((puppy, puppyIndex) => (
      <div class="puppy-card">
        <div class="puppy-gallery">
          <div class="main-image">
            <img id={`main-img-${puppyIndex}`} src={puppy.image} alt={puppy.name} />
            {puppy.status === 'Sold' && (
              <div class="sold-overlay">
                <span class="sold-text">SOLD</span>
              </div>
            )}
          </div>
        </div>

        <div class="puppy-details">
          <div class="details-header">
            <div class="name-section">
              <h2>{puppy.name}</h2>
              <p class="subtitle">ID: HP{String(puppyIndex + 1).padStart(3, '0')}</p>
            </div>
            <span class={`status-badge ${puppy.status.toLowerCase()}`}>{puppy.status}</span>
          </div>

          <div class="price-banner">
            <div class="price-info">
              <span class="price-amount">${puppy.price.toLocaleString('en-US')}</span>
              <span class="price-text">Includes Documentation & Starter Kit</span>
            </div>
            {puppy.status === 'Available' && (
              <a
                href={`sms:+14432263475?&body=${encodeURIComponent(`Hello I am interested in this Dachshund Puppy ${puppy.name} \nwebsite: https://doxiepupscreek.com/available-puppies`)}`}
                class="btn-send-text"
              >
                <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16"><path d="M20 2H4c-1.1 0-2 .9-2 2v18l4-4h14c1.1 0 2-.9 2-2V4c0-1.1-.9-2-2-2zm0 14H5.17L4 17.17V4h16v12z"/><path d="M7 9h2v2H7zm4 0h2v2h-2zm4 0h2v2h-2z"/></svg>
                Send Text
              </a>
            )}
          </div>

          <div class="stats-row">
            <div class="stat-item">
              <div class="stat-icon">
                <svg viewBox="0 0 24 24" fill="currentColor">
                  <circle cx="4.5" cy="9.5" r="2.5"/>
                  <circle cx="9" cy="5.5" r="2.5"/>
                  <circle cx="15" cy="5.5" r="2.5"/>
                  <circle cx="19.5" cy="9.5" r="2.5"/>
                  <path d="M17.34 14.86c-.87-1.02-1.6-1.89-2.48-2.91-.46-.54-1.05-1.08-1.75-1.32-.11-.04-.22-.07-.33-.09-.25-.04-.52-.04-.78-.04s-.53 0-.79.05c-.11.02-.22.05-.33.09-.7.24-1.28.78-1.75 1.32-.87 1.02-1.6 1.89-2.48 2.91-1.31 1.31-2.92 2.76-2.62 4.79.29 1.02 1.02 2.03 2.33 2.32.73.15 3.06-.44 5.54-.44h.18c2.48 0 4.81.58 5.54.44 1.31-.29 2.04-1.31 2.33-2.32.31-2.04-1.3-3.49-2.61-4.8z"/>
                </svg>
              </div>
              <span class="stat-value">{puppy.sex}</span>
              <span class="stat-label">Sex</span>
            </div>
            <div class="stat-item">
              <div class="stat-icon">
                <svg viewBox="0 0 24 24" fill="currentColor">
                  <path d="M19 3h-1V1h-2v2H8V1H6v2H5c-1.11 0-1.99.9-1.99 2L3 19c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V8h14v11zM9 10H7v2h2v-2zm4 0h-2v2h2v-2zm4 0h-2v2h2v-2zm-8 4H7v2h2v-2zm4 0h-2v2h2v-2zm4 0h-2v2h2v-2z"/>
                </svg>
              </div>
              <span class="stat-value">{puppy.age}</span>
              <span class="stat-label">Age</span>
            </div>
            <div class="stat-item">
              <div class="stat-icon">
                <svg viewBox="0 0 24 24" fill="currentColor">
                  <circle cx="4.5" cy="9.5" r="2.5"/>
                  <circle cx="9" cy="5.5" r="2.5"/>
                  <circle cx="15" cy="5.5" r="2.5"/>
                  <circle cx="19.5" cy="9.5" r="2.5"/>
                  <path d="M17.34 14.86c-.87-1.02-1.6-1.89-2.48-2.91-.46-.54-1.05-1.08-1.75-1.32-.11-.04-.22-.07-.33-.09-.25-.04-.52-.04-.78-.04s-.53 0-.79.05c-.11.02-.22.05-.33.09-.7.24-1.28.78-1.75 1.32-.87 1.02-1.6 1.89-2.48 2.91-1.31 1.31-2.92 2.76-2.62 4.79.29 1.02 1.02 2.03 2.33 2.32.73.15 3.06-.44 5.54-.44h.18c2.48 0 4.81.58 5.54.44 1.31-.29 2.04-1.31 2.33-2.32.31-2.04-1.3-3.49-2.61-4.8z"/>
                </svg>
              </div>
              <span class="stat-value">{puppy.breed}</span>
              <span class="stat-label">Breed</span>
            </div>
            <div class="stat-item">
              <div class="stat-icon">
                <svg viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 18c-4.41 0-8-3.59-8-8s3.59-8 8-8 8 3.59 8 8-3.59 8-8 8z"/>
                  <circle cx="12" cy="12" r="5"/>
                </svg>
              </div>
              <span class="stat-value">{puppy.color}</span>
              <span class="stat-label">Color</span>
            </div>
          </div>

          <div class="info-row">
            <div class="info-item">
              <span class="info-label">Puppy ID:</span>
              <span class="info-value">HP{String(puppyIndex + 1).padStart(3, '0')}</span>
            </div>
            <div class="info-item">
              <span class="info-label">Registration:</span>
              <span class="info-value">AKC Registered</span>
            </div>
          </div>

          <p class="description">{puppy.description}</p>

          <div class="comes-with-card">
            <p class="comes-with-title">Each Puppy Includes:</p>
            <ul class="comes-with-list">
              <li>2-year health guarantee</li>
              <li>Up-to-date vaccinations</li>
              <li>Complete deworming</li>
            </ul>
          </div>

          <div class="buttons-row">
            {puppy.status === 'Available' ? (
              <>
                <a href="/contact" class="btn btn-primary btn-contact">Contact Us</a>
                <button type="button" class="btn btn-outline btn-adopt" onclick={`openContactPopup('${puppy.name}', '${puppy.image}', '${puppy.breed} · ${puppy.color}', ${puppy.price})`}>Adopt Me</button>
              </>
            ) : (
              <span class="btn btn-sold">This Puppy Has Been Adopted</span>
            )}
          </div>
          {puppy.status === 'Available' && (
            <a
              href={`sms:+14432263475?&body=${encodeURIComponent(`Hello I am interested in this Dachshund Puppy ${puppy.name} \nwebsite: https://doxiepupscreek.com/available-puppies`)}`}
              class="btn-sms-under"
            >
              Send Text
            </a>
          )}
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .puppies-section {
    padding: 40px 20px;
    background: #FFF8F0;
  }

  .puppies-section .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0;
  }

  .puppy-card {
    display: grid;
    grid-template-columns: 1fr 1fr;
    background: #fff;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
    margin-bottom: 30px;
  }

  .puppy-gallery {
    position: relative;
    min-height: 450px;
  }

  .main-image {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
  }

  .main-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center center;
    display: block;
  }

  .sold-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(0, 0, 0, 0.4);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .sold-text {
    background: #c0392b;
    color: white;
    padding: 0.75rem 2.5rem;
    font-size: 1.5rem;
    font-weight: 900;
    letter-spacing: 3px;
    text-transform: uppercase;
    transform: rotate(-15deg);
    border-radius: 4px;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.3);
  }

  .puppy-details {
    padding: 20px 25px;
    display: flex;
    flex-direction: column;
  }

  .details-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 15px;
  }

  .name-section h2 {
    font-size: 1.5rem;
    color: #333;
    margin: 0 0 3px;
  }

  .subtitle {
    font-size: 0.8rem;
    color: #888;
    margin: 0;
  }

  .status-badge {
    padding: 6px 12px;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    border-radius: 4px;
    letter-spacing: 0.5px;
  }

  .status-badge.available {
    background: #4A7C59;
    color: #fff;
  }

  .status-badge.sold {
    background: #c0392b;
    color: #fff;
  }

  .price-banner {
    background: linear-gradient(135deg, #5C3D2E 0%, #D4A574 100%);
    color: #fff;
    padding: 12px 16px;
    border-radius: 8px;
    margin-bottom: 15px;
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }

  .price-info {
    display: flex;
    align-items: center;
    gap: 10px;
    flex: 1;
    flex-wrap: wrap;
  }

  .price-amount {
    font-size: 1.5rem;
    font-weight: 800;
    color: #fff;
  }

  .price-text {
    font-size: 0.9rem;
    font-weight: 600;
    opacity: 0.95;
  }

  .btn-send-text {
    display: none;
  }

  .stats-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 10px;
    padding: 12px 0;
    border-top: 1px solid #E8DDD4;
    border-bottom: 1px solid #E8DDD4;
    margin-bottom: 12px;
  }

  .stat-item {
    text-align: center;
  }

  .stat-icon {
    width: 28px;
    height: 28px;
    margin: 0 auto 5px;
    color: #5C3D2E;
  }

  .stat-icon svg {
    width: 100%;
    height: 100%;
  }

  .stat-value {
    display: block;
    font-weight: 700;
    color: #333;
    font-size: 0.85rem;
    margin-bottom: 1px;
  }

  .stat-label {
    font-size: 0.65rem;
    color: #888;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .info-row {
    display: flex;
    gap: 20px;
    margin-bottom: 12px;
    flex-wrap: wrap;
  }

  .info-item {
    display: flex;
    gap: 6px;
  }

  .info-label {
    color: #888;
    font-size: 0.8rem;
  }

  .info-value {
    color: #333;
    font-weight: 600;
    font-size: 0.8rem;
  }

  .description {
    font-size: 0.85rem;
    color: #555;
    line-height: 1.6;
    margin-bottom: 15px;
    flex-grow: 1;
  }

  .comes-with-card {
    background: #FFF8F0;
    border: 1px solid #D4A574;
    border-radius: 8px;
    padding: 10px 14px;
    margin-bottom: 15px;
  }

  .comes-with-card .comes-with-title {
    margin: 0 0 8px;
    font-size: 0.85rem;
    color: #3E2518;
    font-weight: 700;
    line-height: 1.5;
  }

  .comes-with-card .comes-with-list {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .comes-with-card .comes-with-list li {
    font-size: 0.8rem;
    color: #3E2518;
    padding: 2px 0;
    padding-left: 18px;
    position: relative;
  }

  .comes-with-card .comes-with-list li::before {
    content: "\2713";
    position: absolute;
    left: 0;
    color: #D4A574;
    font-weight: 700;
  }

  .buttons-row {
    display: flex;
    gap: 10px;
  }

  .buttons-row .btn {
    flex: 1;
    text-align: center;
    padding: 10px 15px;
    font-size: 0.8rem;
    font-weight: 700;
    border-radius: 5px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    transition: all 0.3s ease;
    cursor: pointer;
    text-decoration: none;
  }

  .btn-sms-under {
    display: none;
    width: calc(50% - 5px);
    margin-top: 10px;
    margin-left: calc(50% + 5px);
    text-align: center;
    padding: 10px 15px;
    font-size: 0.8rem;
    font-weight: 700;
    border-radius: 5px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    transition: all 0.3s ease;
    text-decoration: none;
    background: #5C3D2E;
    color: #fff;
    border: 2px solid #5C3D2E;
  }

  .btn-sms-under:hover {
    background: #3E2518;
    border-color: #3E2518;
    color: #fff;
  }

  .btn-primary {
    background: #5C3D2E;
    color: #fff;
    border: 2px solid #5C3D2E;
  }

  .btn-primary:hover {
    background: #3E2518;
    border-color: #3E2518;
    color: #fff;
  }

  .btn-outline {
    background: transparent;
    color: #5C3D2E;
    border: 2px solid #5C3D2E;
  }

  .btn-outline:hover {
    background: #5C3D2E;
    color: #fff;
  }

  .btn-adopt {
    background: #FFF8F0;
    color: #5C3D2E;
    border: 2px solid #D4A574;
    padding-top: 12px;
    padding-bottom: 12px;
  }

  .btn-adopt:hover {
    background: #F6E8D9;
    color: #3E2518;
    border-color: #C79866;
  }

  .btn-sold {
    background: #f5f5f5;
    color: #999;
    border: 2px solid #ddd;
    cursor: default;
    font-style: italic;
  }

  @media (max-width: 900px) {
    .puppy-card {
      grid-template-columns: 1fr;
    }

    .puppy-gallery {
      min-height: auto;
      display: flex;
      flex-direction: column;
    }

    .main-image {
      position: relative;
      height: 380px;
    }

    .buttons-row {
      flex-direction: column;
      gap: 8px;
    }

    .btn-sms-under {
      width: 100%;
      margin-left: 0;
    }
  }

  @media (max-width: 600px) {
    .puppies-section {
      padding: 15px 14px;
    }

    .puppy-card {
      border-radius: 8px;
      margin-bottom: 20px;
    }

    .main-image {
      height: 380px;
    }

    .puppy-details {
      padding: 15px;
    }

    .details-header {
      margin-bottom: 10px;
    }

    .price-banner {
      background: #FFF8F0;
      border: 1px solid #D4A574;
      padding: 10px 12px;
      margin-bottom: 12px;
      align-items: center;
      gap: 8px;
      flex-wrap: nowrap;
    }

    .price-info {
      flex-direction: column;
      align-items: flex-start;
      gap: 2px;
      flex: 1;
    }

    .price-amount {
      color: #5C3D2E;
      font-size: 1.3rem;
      width: auto;
    }

    .price-text {
      color: #888;
      font-size: 0.75rem;
      width: auto;
      opacity: 1;
    }

    .btn-send-text {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      background: #5C3D2E;
      color: white;
      text-decoration: none;
      padding: 8px 14px;
      border-radius: 6px;
      font-size: 0.8rem;
      font-weight: 600;
      cursor: pointer;
      white-space: nowrap;
      flex-shrink: 0;
    }

    .btn-send-text svg {
      width: 15px;
      height: 15px;
    }

    .name-section h2 {
      font-size: 1.25rem;
    }

    .subtitle {
      font-size: 0.75rem;
    }

    .status-badge {
      padding: 5px 10px;
      font-size: 0.65rem;
    }

    .stats-row {
      padding: 10px 0;
      margin-bottom: 10px;
      gap: 5px;
    }

    .stat-icon {
      width: 22px;
      height: 22px;
      margin-bottom: 3px;
    }

    .stat-value {
      font-size: 0.7rem;
    }

    .stat-label {
      font-size: 0.55rem;
    }

    .info-row {
      gap: 12px;
      margin-bottom: 10px;
    }

    .info-label,
    .info-value {
      font-size: 0.75rem;
    }

    .description {
      font-size: 0.8rem;
      line-height: 1.5;
      margin-bottom: 12px;
    }

    .buttons-row .btn {
      padding: 10px 12px;
      font-size: 0.75rem;
    }

    .btn-adopt {
      padding-top: 12px;
      padding-bottom: 12px;
    }

    .btn-sms-under {
      display: inline-block;
      padding: 10px 12px;
      font-size: 0.75rem;
    }

    .buttons-row .btn-contact {
      display: none;
    }
  }
</style>
