---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
---

<BaseLayout
  title="About Us | Dapper Doxie"
  description="Learn about Dapper Doxie, a family Dachshund breeder since 1995. Over 30 years of experience raising healthy, well-socialized Miniature and Standard Dachshund puppies."
  keywords="about Dapper Doxie, Dachshund breeder, family breeder, Miniature Dachshund, Standard Dachshund, Dachshund puppies USA"
>
  <PageHeader
    title="About Us"
    subtitle="Meet the family and passion behind Dapper Doxie, trusted Dachshund breeders since 1995"
  />

  <!-- Our Story Section -->
  <section class="story-section">
    <div class="story-container">
      <div class="story-badge">Our Story</div>
      <h2 class="story-heading">A Family Passion Since 1995</h2>
      <div class="story-content">
        <div class="story-text">
          <p>
            Dapper Doxie was born from our family's deep love for Dachshunds. What started as a passion
            in 1995 has grown into a lifelong commitment to breeding healthy, happy, and well-socialized
            Dachshund puppies in the heart of America.
          </p>
          <p>
            With over <strong>30 years of dedicated breeding experience</strong>, we have perfected our
            approach to raising exceptional Dachshunds. Every puppy is born and raised inside our family
            home, surrounded by love, attention, and the everyday sounds and rhythms of a real household.
            This ensures each puppy develops a confident, well-adjusted temperament before joining your family.
          </p>
          <p>
            We specialize in <strong>three beautiful Dachshund varieties</strong>: the sleek and
            easy-care Miniature Smooth, the elegant and flowing Miniature Longhair, and the bold,
            athletic Standard Smooth. Each variety has its own unique charm, and we are always happy
            to help you choose the perfect match for your lifestyle.
          </p>
          <p>
            Our commitment goes beyond breeding beautiful puppies. Every Dachshund that leaves Dapper Doxie
            is fully vet-checked, vaccinated, microchipped, and comes with a comprehensive health guarantee.
            We perform thorough health testing on all parent dogs, including IVDD screening, PRA testing, and
            cardiac evaluations, because your puppy's health is our top priority.
          </p>
        </div>
        <div class="story-aside">
          <div class="stat-card">
            <span class="stat-number">800+</span>
            <span class="stat-label">Happy Families</span>
          </div>
          <div class="stat-card">
            <span class="stat-number">30+</span>
            <span class="stat-label">Years of Experience</span>
          </div>
          <div class="stat-card">
            <span class="stat-number">3</span>
            <span class="stat-label">Dachshund Varieties</span>
          </div>
          <div class="stat-card">
            <span class="stat-number">100%</span>
            <span class="stat-label">Health Guarantee</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Our Varieties Section -->
  <section class="varieties-section">
    <div class="varieties-container">
      <div class="varieties-badge">Our Varieties</div>
      <h2 class="varieties-heading">Three Beautiful Dachshund Varieties</h2>
      <p class="varieties-subtitle">
        Each variety brings its own special character and charm. Discover which Dachshund is the perfect fit for your family.
      </p>
      <div class="varieties-grid">
        <div class="variety-card">
          <div class="variety-image-wrapper">
            <img src="/images/puppies/BELLA female 9 weeks.jpeg" alt="Miniature Smooth Dachshund puppy from Dapper Doxie" loading="lazy" />
          </div>
          <div class="variety-info">
            <h3>Miniature Smooth</h3>
            <p>The classic Dachshund with a sleek, short coat that is easy to care for. Playful, curious, and full of personality. Perfect for families who want a low-maintenance, affectionate companion.</p>
          </div>
        </div>
        <div class="variety-card">
          <div class="variety-image-wrapper">
            <img src="/images/puppies/ROSIE female 10 weeks.jpeg" alt="Miniature Longhair Dachshund puppy from Dapper Doxie" loading="lazy" />
          </div>
          <div class="variety-info">
            <h3>Miniature Longhair</h3>
            <p>Elegant and graceful with a beautiful flowing coat. Known for their gentle, calm temperament. Ideal for those who enjoy grooming and want a loyal, affectionate lap dog.</p>
          </div>
        </div>
        <div class="variety-card">
          <div class="variety-image-wrapper">
            <img src="/images/puppies/DUKE male 10 weeks.jpeg" alt="Standard Smooth Dachshund puppy from Dapper Doxie" loading="lazy" />
          </div>
          <div class="variety-info">
            <h3>Standard Smooth</h3>
            <p>Bold, athletic, and confident with a sturdy build. The original hunting Dachshund with boundless energy. Great for active families and those with larger living spaces.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Choose Us Section -->
  <section class="reasons-section">
    <div class="reasons-container">
      <div class="reasons-badge">Why Choose Us</div>
      <h2 class="reasons-heading">What Sets Dapper Doxie Apart</h2>
      <p class="reasons-subtitle">
        For over three decades, families across America have trusted us to raise their perfect Dachshund companions.
      </p>
      <div class="reasons-grid">
        <div class="reason-card">
          <div class="reason-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
              <polyline points="9 22 9 12 15 12 15 22"></polyline>
            </svg>
          </div>
          <h3 class="reason-title">Family Raised</h3>
          <p class="reason-description">Every puppy grows up in our home with daily love and attention from our entire family, including children and other dogs.</p>
        </div>
        <div class="reason-card">
          <div class="reason-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
              <path d="M9 12l2 2 4-4"></path>
            </svg>
          </div>
          <h3 class="reason-title">Health Guaranteed</h3>
          <p class="reason-description">Comprehensive 2-year genetic health guarantee with IVDD screening, PRA testing, and cardiac evaluations on all parents.</p>
        </div>
        <div class="reason-card">
          <div class="reason-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
            </svg>
          </div>
          <h3 class="reason-title">Socialized from Birth</h3>
          <p class="reason-description">Puppies interact daily with adults, children, and household sounds, building confidence and a loving temperament.</p>
        </div>
        <div class="reason-card">
          <div class="reason-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
              <polyline points="22 4 12 14.01 9 11.01"></polyline>
            </svg>
          </div>
          <h3 class="reason-title">Vet Checked</h3>
          <p class="reason-description">Every puppy receives a thorough veterinary exam, age-appropriate vaccinations, deworming, and a microchip before going home.</p>
        </div>
        <div class="reason-card">
          <div class="reason-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
              <polyline points="14 2 14 8 20 8"></polyline>
              <line x1="16" y1="13" x2="8" y2="13"></line>
              <line x1="16" y1="17" x2="8" y2="17"></line>
              <polyline points="10 9 9 9 8 9"></polyline>
            </svg>
          </div>
          <h3 class="reason-title">Full Documentation</h3>
          <p class="reason-description">AKC registration, health certificate, vaccination records, microchip registration, and a comprehensive Dachshund care guide.</p>
        </div>
        <div class="reason-card">
          <div class="reason-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
            </svg>
          </div>
          <h3 class="reason-title">Lifetime Support</h3>
          <p class="reason-description">Our relationship does not end at pickup. We are here for advice, questions, and guidance throughout your Dachshund's life.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="cta-section">
    <div class="cta-container">
      <h2 class="cta-heading">Ready to Find Your Perfect Dachshund?</h2>
      <p class="cta-text">
        Browse our available puppies or reach out to learn more about our upcoming litters.
        We would love to help you find the ideal companion for your family.
      </p>
      <div class="cta-buttons">
        <a href="/available-puppies" class="cta-button">View Available Puppies</a>
        <a href="/contact" class="cta-button-outline">Contact Us</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* =============================================
     Story Section
     ============================================= */
  .story-section {
    padding: 5rem 1.5rem;
    background: #ffffff;
  }

  .story-container {
    max-width: 1100px;
    margin: 0 auto;
  }

  .story-badge {
    display: inline-block;
    background: rgba(31, 81, 50, 0.1);
    color: #1F5132;
    padding: 0.4rem 1rem;
    border-radius: 50px;
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 1rem;
  }

  .story-heading {
    font-size: 2.25rem;
    font-weight: 700;
    color: #143521;
    margin: 0 0 2.5rem;
    line-height: 1.3;
  }

  .story-content {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 3rem;
    align-items: start;
  }

  .story-text p {
    font-size: 1.05rem;
    line-height: 1.8;
    color: #5a5a5a;
    margin: 0 0 1.5rem;
  }

  .story-text p:last-child {
    margin-bottom: 0;
  }

  .story-text strong {
    color: #143521;
  }

  .story-aside {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .stat-card {
    background: #F7FAF7;
    border-radius: 12px;
    padding: 1.5rem 1rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    border: 1px solid rgba(46, 107, 69, 0.2);
  }

  .stat-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 25px rgba(31, 81, 50, 0.1);
  }

  .stat-number {
    font-size: 2rem;
    font-weight: 800;
    color: #1F5132;
    line-height: 1.2;
  }

  .stat-label {
    font-size: 0.8rem;
    color: #8a7a6a;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  /* =============================================
     Varieties Section
     ============================================= */
  .varieties-section {
    padding: 5rem 1.5rem;
    background: #F7FAF7;
  }

  .varieties-container {
    max-width: 1100px;
    margin: 0 auto;
    text-align: center;
  }

  .varieties-badge {
    display: inline-block;
    background: rgba(31, 81, 50, 0.1);
    color: #1F5132;
    padding: 0.4rem 1rem;
    border-radius: 50px;
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 1rem;
  }

  .varieties-heading {
    font-size: 2.25rem;
    font-weight: 700;
    color: #143521;
    margin: 0 0 1rem;
    line-height: 1.3;
  }

  .varieties-subtitle {
    font-size: 1.1rem;
    color: #8a7a6a;
    max-width: 650px;
    margin: 0 auto 3rem;
    line-height: 1.7;
  }

  .varieties-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .variety-card {
    border-radius: 16px;
    overflow: hidden;
    background: #ffffff;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    border: 1px solid rgba(46, 107, 69, 0.15);
  }

  .variety-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 16px 40px rgba(31, 81, 50, 0.12);
  }

  .variety-image-wrapper {
    position: relative;
    width: 100%;
    padding-top: 100%;
    overflow: hidden;
  }

  .variety-image-wrapper img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .variety-card:hover .variety-image-wrapper img {
    transform: scale(1.05);
  }

  .variety-info {
    padding: 1.5rem;
    text-align: left;
  }

  .variety-info h3 {
    font-size: 1.25rem;
    font-weight: 700;
    color: #143521;
    margin: 0 0 0.5rem;
  }

  .variety-info p {
    font-size: 0.92rem;
    color: #6b6b6b;
    line-height: 1.7;
    margin: 0;
  }

  /* =============================================
     Why Choose Us Section
     ============================================= */
  .reasons-section {
    padding: 5rem 1.5rem;
    background: #ffffff;
  }

  .reasons-container {
    max-width: 1100px;
    margin: 0 auto;
    text-align: center;
  }

  .reasons-badge {
    display: inline-block;
    background: rgba(31, 81, 50, 0.1);
    color: #1F5132;
    padding: 0.4rem 1rem;
    border-radius: 50px;
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 1rem;
  }

  .reasons-heading {
    font-size: 2.25rem;
    font-weight: 700;
    color: #143521;
    margin: 0 0 1rem;
    line-height: 1.3;
  }

  .reasons-subtitle {
    font-size: 1.1rem;
    color: #8a7a6a;
    max-width: 650px;
    margin: 0 auto 3rem;
    line-height: 1.7;
  }

  .reasons-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .reason-card {
    background: #F7FAF7;
    border-radius: 16px;
    padding: 2rem 1.5rem;
    text-align: center;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    border: 1px solid rgba(46, 107, 69, 0.15);
  }

  .reason-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 12px 35px rgba(31, 81, 50, 0.1);
  }

  .reason-icon {
    width: 64px;
    height: 64px;
    border-radius: 16px;
    background: linear-gradient(135deg, rgba(31, 81, 50, 0.1) 0%, rgba(46, 107, 69, 0.15) 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1.25rem;
    color: #1F5132;
  }

  .reason-title {
    font-size: 1.05rem;
    font-weight: 700;
    color: #143521;
    margin: 0 0 0.75rem;
  }

  .reason-description {
    font-size: 0.9rem;
    color: #6b6b6b;
    line-height: 1.7;
    margin: 0;
  }

  /* =============================================
     CTA Section
     ============================================= */
  .cta-section {
    padding: 5rem 1.5rem;
    background: linear-gradient(135deg, #143521 0%, #1F5132 50%, #2E6B45 100%);
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .cta-section::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.04'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
    pointer-events: none;
  }

  .cta-container {
    max-width: 700px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .cta-heading {
    font-size: 2.25rem;
    font-weight: 700;
    color: #ffffff;
    margin: 0 0 1.25rem;
    line-height: 1.3;
  }

  .cta-text {
    font-size: 1.1rem;
    color: rgba(255, 255, 255, 0.85);
    line-height: 1.7;
    margin: 0 0 2rem;
  }

  .cta-buttons {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .cta-button {
    display: inline-block;
    background: #ffffff;
    color: #143521;
    padding: 1rem 2.5rem;
    border-radius: 50px;
    font-size: 1.05rem;
    font-weight: 700;
    text-decoration: none;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .cta-button:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
  }

  .cta-button-outline {
    display: inline-block;
    background: transparent;
    color: #ffffff;
    padding: 1rem 2.5rem;
    border-radius: 50px;
    font-size: 1.05rem;
    font-weight: 700;
    text-decoration: none;
    border: 2px solid rgba(255, 255, 255, 0.6);
    transition: all 0.3s ease;
  }

  .cta-button-outline:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: #ffffff;
    transform: translateY(-2px);
  }

  /* =============================================
     Responsive Design
     ============================================= */
  @media (max-width: 1024px) {
    .reasons-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .story-section,
    .varieties-section,
    .reasons-section,
    .cta-section {
      padding: 3.5rem 1.25rem;
    }

    .story-heading,
    .varieties-heading,
    .reasons-heading,
    .cta-heading {
      font-size: 1.75rem;
    }

    .story-content {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .story-aside {
      grid-template-columns: repeat(4, 1fr);
      gap: 0.75rem;
    }

    .stat-card {
      padding: 1rem 0.75rem;
    }

    .stat-number {
      font-size: 1.5rem;
    }

    .varieties-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
      max-width: 400px;
      margin: 0 auto;
    }

    .reasons-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
    }

    .reason-card {
      padding: 1.5rem 1rem;
    }
  }

  @media (max-width: 576px) {
    .story-section,
    .varieties-section,
    .reasons-section,
    .cta-section {
      padding: 3rem 1rem;
    }

    .story-heading,
    .varieties-heading,
    .reasons-heading,
    .cta-heading {
      font-size: 1.5rem;
    }

    .story-text p {
      font-size: 0.95rem;
    }

    .story-aside {
      grid-template-columns: repeat(2, 1fr);
    }

    .reasons-grid {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .reason-card {
      display: grid;
      grid-template-columns: 56px 1fr;
      grid-template-rows: auto auto;
      column-gap: 1rem;
      row-gap: 0.25rem;
      text-align: left;
      padding: 1.25rem;
    }

    .reason-icon {
      grid-row: 1 / 3;
      width: 56px;
      height: 56px;
      margin: 0;
      border-radius: 12px;
      align-self: center;
    }

    .reason-icon svg {
      width: 26px;
      height: 26px;
    }

    .reason-title {
      margin: 0;
      align-self: end;
    }

    .reason-description {
      font-size: 0.85rem;
      align-self: start;
    }

    .varieties-subtitle,
    .reasons-subtitle {
      font-size: 1rem;
    }

    .cta-text {
      font-size: 1rem;
    }

    .cta-button,
    .cta-button-outline {
      padding: 0.875rem 2rem;
      font-size: 1rem;
    }

    .cta-buttons {
      flex-direction: column;
      align-items: center;
    }
  }
</style>
