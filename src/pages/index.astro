---
import BaseLayout from '../layouts/BaseLayout.astro';
import { puppies } from '../data/puppies';
import { testimonials } from '../data/testimonials';

const availablePuppies = puppies.filter(p => p.status === 'Available').slice(0, 6);
const heroPuppy = availablePuppies[0] || puppies[0];
const featuredTestimonials = testimonials.slice(0, 3);
---

<BaseLayout
  title="Dapper Doxie | Family-Raised Dachshund Puppies Since 1995"
  description="Find your perfect Dachshund puppy at Dapper Doxie. Family-raised since 1995, health guaranteed, and ready for their forever home."
  keywords="Dachshund puppies, miniature Dachshund, Dachshund breeder, family raised Dachshund, Dapper Doxie"
  ogTitle="Dapper Doxie — Family-Raised Dachshund Puppies Since 1995"
  ogDescription="Discover your perfect Dachshund companion at Dapper Doxie. Healthy, socialized puppies with a lifetime of breeder support."
>
  <div class="home">

    <!-- HERO: big playful card -->
    <section class="hero-card-section">
      <div class="hero-card">
        <div class="hero-card-text">
          <span class="hero-pill">🌿 Family Breeders Since 1995</span>
          <h1>The cutest little<br/><span class="underline-pop">Dachshund</span> puppies, raised in our home.</h1>
          <p>We are a small family breeder hand-raising healthy, happy doxies that are ready to fill your home with wiggles, kisses and tiny zoomies.</p>
          <div class="hero-btns">
            <a href="/available-puppies" class="btn-pop">Meet the puppies →</a>
            <a href="/contact" class="btn-ghost">Say hi</a>
          </div>
          <div class="hero-stats">
            <div><strong>30+</strong><span>Years breeding</span></div>
            <div><strong>500+</strong><span>Happy homes</span></div>
            <div><strong>100%</strong><span>Health guarantee</span></div>
          </div>
        </div>
        <div class="hero-card-image">
          <div class="hero-image-wrap">
            <img src={heroPuppy.image} alt={heroPuppy.name} />
            <div class="hero-image-badge">
              <span class="badge-dot"></span>
              {availablePuppies.length} puppies available now
            </div>
          </div>
          <div class="hero-floater hero-floater-1">🐾</div>
          <div class="hero-floater hero-floater-2">💚</div>
          <div class="hero-floater hero-floater-3">⭐</div>
        </div>
      </div>
    </section>

    <!-- MARQUEE strip -->
    <div class="marquee">
      <div class="marquee-track">
        <span>🐶 Family raised</span><span>•</span>
        <span>🩺 Vet checked</span><span>•</span>
        <span>💚 Health guaranteed</span><span>•</span>
        <span>✈️ Nationwide delivery</span><span>•</span>
        <span>📚 Lifetime support</span><span>•</span>
        <span>🐶 Family raised</span><span>•</span>
        <span>🩺 Vet checked</span><span>•</span>
        <span>💚 Health guaranteed</span><span>•</span>
        <span>✈️ Nationwide delivery</span><span>•</span>
        <span>📚 Lifetime support</span><span>•</span>
      </div>
    </div>

    <!-- VALUE CARDS -->
    <section class="cards-section">
      <div class="section-head">
        <span class="eyebrow">Why families pick us</span>
        <h2>Tiny dogs, <em>huge</em> standards.</h2>
      </div>
      <div class="cards-grid">
        <div class="value-card vc-1">
          <div class="vc-icon">🏡</div>
          <h3>Raised in our home</h3>
          <p>No kennels, no cages. Our puppies grow up underfoot with kids, cats and a whole lot of love.</p>
        </div>
        <div class="value-card vc-2">
          <div class="vc-icon">🩺</div>
          <h3>Vet-checked & up to date</h3>
          <p>Every pup leaves with current vaccinations, deworming and a clean bill of health from our vet.</p>
        </div>
        <div class="value-card vc-3">
          <div class="vc-icon">💚</div>
          <h3>2-year health guarantee</h3>
          <p>We stand behind every puppy with one of the strongest health guarantees in the country.</p>
        </div>
        <div class="value-card vc-4">
          <div class="vc-icon">✈️</div>
          <h3>Anywhere in the USA</h3>
          <p>Safe nationwide ground & flight nanny delivery — your pup arrives loved, never shipped like cargo.</p>
        </div>
      </div>
    </section>

    <!-- PUPPIES GRID -->
    <section class="puppies-section">
      <div class="section-head">
        <span class="eyebrow">Ready to meet you</span>
        <h2>Available puppies</h2>
        <p class="lead">Click any pup to see photos, parents and pricing.</p>
      </div>
      <div class="puppies-grid">
        {availablePuppies.map((puppy, i) => (
          <a href="/available-puppies" class={`puppy-card pc-${(i % 4) + 1}`}>
            <div class="puppy-image">
              <img src={puppy.image} alt={puppy.name} loading="lazy" />
              <span class="puppy-status">Available</span>
            </div>
            <div class="puppy-info">
              <div class="puppy-name-row">
                <h3>{puppy.name}</h3>
                <span class="puppy-sex">{puppy.sex === 'Female' ? '♀' : '♂'}</span>
              </div>
              <p class="puppy-meta">{puppy.age} · {puppy.color}</p>
              <span class="puppy-cta">View details →</span>
            </div>
          </a>
        ))}
      </div>
      <div class="puppies-cta">
        <a href="/available-puppies" class="btn-pop">See every available puppy</a>
      </div>
    </section>

    <!-- STORY split card -->
    <section class="story-section">
      <div class="story-card">
        <div class="story-pic">
          <img src="/images/puppies/COPPER male 10 weeks.jpeg" alt="Dachshund puppy" />
        </div>
        <div class="story-text">
          <span class="eyebrow light">Our story</span>
          <h2>30 years of wagging tails.</h2>
          <p>Dapper Doxie started in 1995 with one little dachshund named Pepper and a tiny patch of land. Three decades and hundreds of happy families later, we're still doing it the same way — small litters, raised at home, matched carefully with the right family.</p>
          <p>We don't ship and forget. Every puppy comes with lifetime breeder support, so you're never figuring it out alone.</p>
          <a href="/about" class="btn-ghost-dark">Read our story →</a>
        </div>
      </div>
    </section>

    <!-- TESTIMONIALS as bubble cards -->
    <section class="reviews-section">
      <div class="section-head">
        <span class="eyebrow">Love letters</span>
        <h2>What our families say.</h2>
      </div>
      <div class="reviews-grid">
        {featuredTestimonials.map((t, i) => (
          <div class={`review-card rc-${(i % 3) + 1}`}>
            <div class="review-stars">★★★★★</div>
            <p class="review-text">"{t.text}"</p>
            <div class="review-author">
              <div class="review-avatar">{t.name.charAt(0)}</div>
              <div>
                <strong>{t.name}</strong>
                <span>{t.location}</span>
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- FINAL CTA card -->
    <section class="cta-section">
      <div class="cta-card">
        <div class="cta-emoji">🐾</div>
        <h2>Ready to bring home a wiggle butt?</h2>
        <p>Reach out today — we'd love to help you find the perfect doxie for your family.</p>
        <div class="cta-buttons">
          <a href="/contact" class="btn-pop btn-white">Get in touch</a>
          <a href="/faq" class="btn-ghost-light">Read our FAQ</a>
        </div>
      </div>
    </section>

  </div>
</BaseLayout>

<style>
  :root {
    --fg: #1F5132;
    --fg-dark: #143521;
    --fg-light: #2E6B45;
    --fg-soft: #EEF3EE;
    --fg-cream: #F7FAF7;
    --ink: #14201A;
    --line: #C9D3CA;
  }

  .home {
    background: var(--fg-cream);
    font-family: var(--font-family, 'Segoe UI', sans-serif);
    color: var(--ink);
    overflow-x: hidden;
  }

  .home :global(section) {
    padding: 0;
  }

  /* Shared headings */
  .section-head {
    text-align: center;
    max-width: 720px;
    margin: 0 auto 2.5rem;
  }

  .eyebrow {
    display: inline-block;
    background: var(--fg);
    color: white;
    padding: 0.3rem 0.9rem;
    border-radius: 999px;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    margin-bottom: 1rem;
  }

  .eyebrow.light {
    background: rgba(255,255,255,0.18);
    color: white;
    border: 1px solid rgba(255,255,255,0.3);
  }

  .section-head h2 {
    font-size: 2.75rem;
    line-height: 1.05;
    margin: 0 0 0.75rem;
    color: var(--ink);
    letter-spacing: -1px;
  }

  .section-head h2 em {
    font-style: italic;
    color: var(--fg);
  }

  .section-head .lead {
    color: #4E5A52;
    font-size: 1.05rem;
    margin: 0;
  }

  /* HERO */
  .hero-card-section {
    padding: 2.5rem 1.5rem 1.5rem;
  }

  .hero-card {
    max-width: 1200px;
    margin: 0 auto;
    background: var(--fg);
    border-radius: 36px;
    padding: 3rem;
    color: white;
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: 3rem;
    align-items: center;
    position: relative;
    box-shadow: 0 30px 80px rgba(20, 53, 33, 0.25);
    overflow: hidden;
  }

  .hero-card::before {
    content: '';
    position: absolute;
    top: -80px;
    right: -80px;
    width: 280px;
    height: 280px;
    background: rgba(255,255,255,0.06);
    border-radius: 50%;
  }

  .hero-card::after {
    content: '';
    position: absolute;
    bottom: -100px;
    left: -60px;
    width: 240px;
    height: 240px;
    background: rgba(255,255,255,0.05);
    border-radius: 50%;
  }

  .hero-card-text {
    position: relative;
    z-index: 2;
  }

  .hero-pill {
    display: inline-block;
    background: rgba(255,255,255,0.15);
    border: 1px solid rgba(255,255,255,0.3);
    padding: 0.45rem 1rem;
    border-radius: 999px;
    font-size: 0.78rem;
    font-weight: 600;
    margin-bottom: 1.5rem;
  }

  .hero-card-text h1 {
    font-size: 3.25rem;
    line-height: 1.05;
    margin: 0 0 1.25rem;
    color: white;
    letter-spacing: -1.5px;
    font-weight: 800;
  }

  .underline-pop {
    position: relative;
    display: inline-block;
  }

  .underline-pop::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: 4px;
    height: 14px;
    background: rgba(255,255,255,0.22);
    border-radius: 8px;
    z-index: -1;
  }

  .hero-card-text > p {
    font-size: 1.1rem;
    line-height: 1.6;
    color: rgba(255,255,255,0.85);
    margin: 0 0 1.75rem;
    max-width: 480px;
  }

  .hero-btns {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 2rem;
  }

  .btn-pop {
    display: inline-flex;
    align-items: center;
    background: white;
    color: var(--fg);
    padding: 1rem 1.75rem;
    border-radius: 16px;
    font-weight: 700;
    text-decoration: none;
    font-size: 0.95rem;
    box-shadow: 0 6px 0 var(--fg-dark);
    transition: all 0.2s ease;
  }

  .btn-pop:hover {
    transform: translateY(-3px);
    box-shadow: 0 9px 0 var(--fg-dark);
    color: var(--fg);
  }

  .btn-pop.btn-white {
    background: white;
    color: var(--fg);
    box-shadow: 0 6px 0 rgba(0,0,0,0.15);
  }

  .btn-pop.btn-white:hover {
    box-shadow: 0 9px 0 rgba(0,0,0,0.15);
  }

  .btn-ghost {
    display: inline-flex;
    align-items: center;
    background: transparent;
    color: white;
    padding: 1rem 1.75rem;
    border-radius: 16px;
    font-weight: 700;
    text-decoration: none;
    font-size: 0.95rem;
    border: 2px solid rgba(255,255,255,0.4);
    transition: all 0.2s ease;
  }

  .btn-ghost:hover {
    background: rgba(255,255,255,0.1);
    border-color: white;
    color: white;
  }

  .btn-ghost-dark {
    display: inline-flex;
    align-items: center;
    background: transparent;
    color: white;
    padding: 0.85rem 1.5rem;
    border-radius: 14px;
    font-weight: 700;
    text-decoration: none;
    font-size: 0.95rem;
    border: 2px solid rgba(255,255,255,0.45);
    transition: all 0.2s ease;
    margin-top: 0.5rem;
  }

  .btn-ghost-dark:hover {
    background: white;
    color: var(--fg);
  }

  .btn-ghost-light {
    display: inline-flex;
    align-items: center;
    background: transparent;
    color: white;
    padding: 1rem 1.75rem;
    border-radius: 16px;
    font-weight: 700;
    text-decoration: none;
    font-size: 0.95rem;
    border: 2px solid rgba(255,255,255,0.5);
    transition: all 0.2s ease;
  }

  .btn-ghost-light:hover {
    background: rgba(255,255,255,0.1);
    color: white;
  }

  .hero-stats {
    display: flex;
    gap: 2.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(255,255,255,0.18);
  }

  .hero-stats > div {
    display: flex;
    flex-direction: column;
  }

  .hero-stats strong {
    font-size: 1.75rem;
    font-weight: 800;
    color: white;
    line-height: 1;
    margin-bottom: 0.25rem;
  }

  .hero-stats span {
    font-size: 0.78rem;
    color: rgba(255,255,255,0.7);
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .hero-card-image {
    position: relative;
    z-index: 2;
  }

  .hero-image-wrap {
    position: relative;
    border-radius: 28px;
    overflow: hidden;
    aspect-ratio: 1 / 1;
    background: rgba(255,255,255,0.1);
    box-shadow: 0 20px 50px rgba(0,0,0,0.25);
    transform: rotate(2deg);
  }

  .hero-image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-image-badge {
    position: absolute;
    bottom: 1.25rem;
    left: 1.25rem;
    background: white;
    color: var(--fg);
    padding: 0.7rem 1.1rem;
    border-radius: 999px;
    font-size: 0.85rem;
    font-weight: 700;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    box-shadow: 0 8px 20px rgba(0,0,0,0.15);
  }

  .badge-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--fg);
    animation: pulse 1.8s infinite;
  }

  @keyframes pulse {
    0%,100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  .hero-floater {
    position: absolute;
    background: white;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    box-shadow: 0 8px 18px rgba(0,0,0,0.18);
    animation: bob 3s ease-in-out infinite;
  }

  .hero-floater-1 { top: -10px; left: -10px; animation-delay: 0s; }
  .hero-floater-2 { top: 40%; right: -20px; animation-delay: 0.7s; }
  .hero-floater-3 { bottom: 10%; left: -25px; animation-delay: 1.4s; }

  @keyframes bob {
    0%, 100% { transform: translateY(0) rotate(-5deg); }
    50% { transform: translateY(-12px) rotate(5deg); }
  }

  /* MARQUEE */
  .marquee {
    background: var(--fg-dark);
    color: white;
    overflow: hidden;
    padding: 1rem 0;
    margin: 2rem 0;
  }

  .marquee-track {
    display: flex;
    gap: 2rem;
    white-space: nowrap;
    animation: scroll 30s linear infinite;
    font-weight: 700;
    font-size: 1rem;
  }

  .marquee-track span {
    flex-shrink: 0;
  }

  @keyframes scroll {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  /* VALUE CARDS */
  .cards-section {
    padding: 4rem 1.5rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .cards-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
  }

  .value-card {
    background: white;
    border-radius: 24px;
    padding: 1.75rem;
    border: 2px solid var(--line);
    transition: all 0.25s ease;
    position: relative;
  }

  .value-card:hover {
    transform: translateY(-6px);
    border-color: var(--fg);
    box-shadow: 0 14px 30px rgba(20,53,33,0.12);
  }

  .vc-2 { background: var(--fg); color: white; border-color: var(--fg); }
  .vc-2 h3 { color: white; }
  .vc-2 p { color: rgba(255,255,255,0.85); }
  .vc-2:hover { background: var(--fg-dark); }

  .vc-icon {
    width: 56px;
    height: 56px;
    background: var(--fg-soft);
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.75rem;
    margin-bottom: 1rem;
  }

  .vc-2 .vc-icon {
    background: rgba(255,255,255,0.15);
  }

  .value-card h3 {
    font-size: 1.15rem;
    margin: 0 0 0.5rem;
    color: var(--ink);
  }

  .value-card p {
    font-size: 0.92rem;
    line-height: 1.55;
    color: #4E5A52;
    margin: 0;
  }

  /* PUPPIES */
  .puppies-section {
    padding: 4rem 1.5rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .puppies-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .puppy-card {
    background: white;
    border-radius: 24px;
    overflow: hidden;
    border: 2px solid var(--line);
    text-decoration: none;
    color: inherit;
    transition: all 0.25s ease;
    display: block;
  }

  .puppy-card:hover {
    transform: translateY(-6px) rotate(-0.5deg);
    border-color: var(--fg);
    box-shadow: 0 18px 36px rgba(20,53,33,0.14);
    color: inherit;
  }

  .puppy-image {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: var(--fg-soft);
  }

  .puppy-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .puppy-card:hover .puppy-image img {
    transform: scale(1.05);
  }

  .puppy-status {
    position: absolute;
    top: 1rem;
    left: 1rem;
    background: var(--fg);
    color: white;
    padding: 0.35rem 0.85rem;
    border-radius: 999px;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .puppy-info {
    padding: 1.25rem 1.4rem 1.5rem;
  }

  .puppy-name-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.25rem;
  }

  .puppy-name-row h3 {
    font-size: 1.4rem;
    margin: 0;
    color: var(--ink);
  }

  .puppy-sex {
    font-size: 1.3rem;
    color: var(--fg);
    font-weight: 700;
  }

  .puppy-meta {
    color: #4E5A52;
    font-size: 0.88rem;
    margin: 0 0 0.85rem;
  }

  .puppy-cta {
    color: var(--fg);
    font-weight: 700;
    font-size: 0.9rem;
  }

  .puppies-cta {
    text-align: center;
    margin-top: 2.5rem;
  }

  /* STORY */
  .story-section {
    padding: 4rem 1.5rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .story-card {
    background: var(--fg);
    border-radius: 36px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    overflow: hidden;
    box-shadow: 0 24px 60px rgba(20,53,33,0.2);
  }

  .story-pic {
    aspect-ratio: 1 / 1;
    overflow: hidden;
  }

  .story-pic img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .story-text {
    padding: 3rem;
    color: white;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .story-text h2 {
    color: white;
    font-size: 2.5rem;
    line-height: 1.1;
    margin: 0.75rem 0 1rem;
    letter-spacing: -1px;
  }

  .story-text p {
    color: rgba(255,255,255,0.88);
    font-size: 1rem;
    line-height: 1.65;
    margin: 0 0 1rem;
  }

  /* REVIEWS */
  .reviews-section {
    padding: 4rem 1.5rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .reviews-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .review-card {
    background: white;
    border: 2px solid var(--line);
    border-radius: 24px;
    padding: 1.75rem;
    transition: all 0.25s ease;
  }

  .review-card:hover {
    transform: translateY(-6px);
    border-color: var(--fg);
    box-shadow: 0 14px 30px rgba(20,53,33,0.12);
  }

  .rc-2 { transform: rotate(-0.5deg); }
  .rc-2:hover { transform: translateY(-6px) rotate(-0.5deg); }
  .rc-1 { transform: rotate(0.5deg); }
  .rc-1:hover { transform: translateY(-6px) rotate(0.5deg); }

  .review-stars {
    color: #F5B042;
    font-size: 1.1rem;
    letter-spacing: 2px;
    margin-bottom: 0.75rem;
  }

  .review-text {
    font-size: 0.98rem;
    line-height: 1.6;
    color: #232E28;
    margin: 0 0 1.5rem;
    font-style: italic;
  }

  .review-author {
    display: flex;
    align-items: center;
