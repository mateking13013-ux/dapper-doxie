---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import PuppyCard from '../components/PuppyCard.astro';
import TestimonialsPreview from '../components/TestimonialsPreview.astro';
import ContactPopup from '../components/ContactPopup.astro';
import { puppies, getAvailablePuppies, getSoldPuppies } from '../data/puppies';

const availablePuppies = getAvailablePuppies();
const soldPuppies = getSoldPuppies();
const allPuppies = [...availablePuppies, ...soldPuppies];
const femaleCount = puppies.filter(p => p.sex === 'Female').length;
const maleCount = puppies.filter(p => p.sex === 'Male').length;
const minPrice = Math.min(...availablePuppies.map(p => p.price));
---

<BaseLayout
  title="Available Dachshund Puppies | HillSide Paws"
  description={`${availablePuppies.length} Dachshund puppies available now. Family-raised since 1995, health guaranteed, and ready for their forever home.`}
  keywords="Dachshund puppies for sale, miniature Dachshund, Dachshund breeder, available puppies, HillSide Paws"
  ogTitle="Available Dachshund Puppies | HillSide Paws"
  ogDescription={`${availablePuppies.length} adorable Dachshund puppies looking for their forever home. Health guaranteed, vet-checked, family-raised.`}
>
  <PageHeader
    title="Available Puppies"
    subtitle="Find your perfect Dachshund companion from our adorable family-raised puppies"
    breadcrumbs={[
      { label: 'Home', href: '/' },
      { label: 'Available Puppies' }
    ]}
  />

  <section class="breed-intro">
    <div class="intro-container">
      <div class="intro-stats">
        <div class="stat-item">
          <span class="stat-number">{availablePuppies.length}</span>
          <span class="stat-label">Available Now</span>
        </div>
        <div class="stat-item">
          <span class="stat-number">{femaleCount}</span>
          <span class="stat-label">Females</span>
        </div>
        <div class="stat-item">
          <span class="stat-number">{maleCount}</span>
          <span class="stat-label">Males</span>
        </div>
        <div class="stat-item">
          <span class="stat-number">${minPrice.toLocaleString('en-US')}</span>
          <span class="stat-label">Starting At</span>
        </div>
      </div>
    </div>
  </section>

  <PuppyCard puppies={allPuppies} />
  <TestimonialsPreview />
  <ContactPopup />
</BaseLayout>

<style>
  .breed-intro {
    display: block;
    font-family: var(--font-family, 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif);
    background: white;
    padding: 2rem 1.5rem;
    border-bottom: 1px solid #eee;
  }

  .intro-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .intro-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    text-align: center;
  }

  .stat-item {
    padding: 1rem;
    background: #FFF8F0;
    border-radius: 12px;
  }

  .stat-number {
    display: block;
    font-size: 1.5rem;
    font-weight: 800;
    color: #5C3D2E;
    margin-bottom: 0.25rem;
  }

  .stat-label {
    display: block;
    font-size: 0.8rem;
    color: #666;
    font-weight: 600;
    text-transform: uppercase;
  }

  @media (max-width: 600px) {
    .intro-stats {
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
    }

    .stat-number {
      font-size: 1.25rem;
    }
  }
</style>
