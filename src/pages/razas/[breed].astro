---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import KittenCard from '../../components/KittenCard.astro';
import TestimonialsPreview from '../../components/TestimonialsPreview.astro';
import ContactPopup from '../../components/ContactPopup.astro';
import { breeds } from '../../data/breeds';
import { getKittensByBreed } from '../../data/kittens';

export function getStaticPaths() {
  return breeds.map(breed => ({
    params: { breed: breed.id },
    props: { breed }
  }));
}

const { breed } = Astro.props;
const breedKittens = getKittensByBreed(breed.id);
---

<BaseLayout
  title={`${breed.name} — Gatitos Disponibles | Criadero Castellano`}
  description={`Descubre nuestros gatitos ${breed.name} disponibles. ${breed.description.substring(0, 120)}...`}
  keywords={`${breed.name}, gatitos ${breed.name}, criadero ${breed.name} España, comprar ${breed.name}`}
  ogTitle={`Gatitos ${breed.name} | Criadero Castellano`}
  ogDescription={`${breedKittens.length} gatitos ${breed.name} disponibles. Criados con amor, con garantía de salud y documentación completa.`}
>
  <PageHeader
    title={`Gatitos ${breed.name}`}
    subtitle={breed.description}
    breadcrumbs={[
      { label: 'Inicio', href: '/' },
      { label: 'Razas', href: '/razas' },
      { label: breed.name }
    ]}
  />

  <section class="breed-intro">
    <div class="intro-container">
      <div class="intro-stats">
        <div class="stat-item">
          <span class="stat-number">{breedKittens.length}</span>
          <span class="stat-label">Gatitos Disponibles</span>
        </div>
        <div class="stat-item">
          <span class="stat-number">{breedKittens.filter(k => k.sex === 'Hembra').length}</span>
          <span class="stat-label">Hembras</span>
        </div>
        <div class="stat-item">
          <span class="stat-number">{breedKittens.filter(k => k.sex === 'Macho').length}</span>
          <span class="stat-label">Machos</span>
        </div>
        <div class="stat-item">
          <span class="stat-number">{Math.min(...breedKittens.map(k => k.price)).toLocaleString('de-DE')} &euro;</span>
          <span class="stat-label">Desde</span>
        </div>
      </div>
    </div>
  </section>

  <KittenCard kittens={breedKittens} />
  <TestimonialsPreview />
  <ContactPopup />
</BaseLayout>

<style>
  .breed-intro {
    display: block;
    font-family: var(--font-family, 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif);
    background: white;
    padding: 2rem 1.5rem;
    border-bottom: 1px solid #eee;
  }

  .intro-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .intro-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    text-align: center;
  }

  .stat-item {
    padding: 1rem;
    background: #F0F4F8;
    border-radius: 12px;
  }

  .stat-number {
    display: block;
    font-size: 1.5rem;
    font-weight: 800;
    color: #1B2A4A;
    margin-bottom: 0.25rem;
  }

  .stat-label {
    display: block;
    font-size: 0.8rem;
    color: #666;
    font-weight: 600;
    text-transform: uppercase;
  }

  @media (max-width: 600px) {
    .intro-stats {
      grid-template-columns: repeat(2, 1fr);
      gap: 1rem;
    }

    .stat-number {
      font-size: 1.25rem;
    }
  }
</style>
