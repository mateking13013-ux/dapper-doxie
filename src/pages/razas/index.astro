---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PageHeader from '../../components/PageHeader.astro';
import ContactPopup from '../../components/ContactPopup.astro';
import { breeds } from '../../data/breeds';
import { kittens } from '../../data/kittens';

// Build detailed breed stats
const breedData = breeds.map(breed => {
  const breedKittens = kittens.filter(k => k.breed === breed.id);
  return {
    ...breed,
    total: breedKittens.length,
    males: breedKittens.filter(k => k.sex === 'Macho').length,
    females: breedKittens.filter(k => k.sex === 'Hembra').length,
    ages: [...new Set(breedKittens.map(k => k.age))],
  };
});
---

<BaseLayout
  title="Razas de Gatos | Criadero Castellano"
  description="Descubre nuestras 11 razas de gatos disponibles. Desde el majestuoso Maine Coon hasta el elegante Azul Ruso. Gatitos de raza criados con amor en España."
  keywords="razas de gatos, gatitos de raza, criadero de gatos España, Maine Coon, British Shorthair, Ragdoll, Persa, Sphynx"
  ogTitle="Razas de Gatos | Criadero Castellano"
  ogDescription="Explora nuestras razas de gatos disponibles. Gatitos sanos, socializados y con garantía de salud."
>
  <PageHeader
    title="Nuestras Razas"
    subtitle="Descubre las 11 razas de gatos que criamos con amor y dedicación en Criadero Castellano"
    breadcrumbs={[
      { label: 'Inicio', href: '/' },
      { label: 'Razas' }
    ]}
  />

  <section class="breeds-section">
    <div class="breeds-container">
      <div class="breeds-header">
        <div class="total-badge">{kittens.length} gatitos disponibles en {breeds.length} razas</div>
      </div>

      <div class="breeds-grid">
        {breedData.map((breed) => (
          <a href={`/razas/${breed.id}`} class="breed-card">
            <div class="breed-image">
              <img src={breed.image} alt={breed.name} loading="lazy">
              <div class="image-overlay">
                <span class="overlay-cta">Ver Gatitos</span>
              </div>
              <div class="breed-badge">{breed.total} disponibles</div>
            </div>
            <div class="breed-body">
              <div class="breed-title-row">
                <h3 class="breed-name">{breed.name}</h3>
                <span class="breed-price">Desde 1.200 &euro;</span>
              </div>

              <div class="breed-stats">
                <div class="stat">
                  <span class="stat-number">{breed.total}</span>
                  <span class="stat-text">Gatitos</span>
                </div>
                <div class="stat-divider"></div>
                <div class="stat">
                  <span class="stat-number">{breed.females}</span>
                  <span class="stat-text">Hembras</span>
                </div>
                <div class="stat-divider"></div>
                <div class="stat">
                  <span class="stat-number">{breed.males}</span>
                  <span class="stat-text">Machos</span>
                </div>
              </div>

              <p class="breed-description">{breed.description}</p>

              <div class="breed-tags">
                <span class="tag">
                  <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
                  Vacunados
                </span>
                <span class="tag">
                  <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor"><path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm-2 16l-4-4 1.41-1.41L10 14.17l6.59-6.59L18 9l-8 8z"/></svg>
                  Garantía 2 Años
                </span>
                <span class="tag">
                  <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor"><path d="M14 2H6c-1.1 0-2 .9-2 2v16c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2V8l-6-6zm2 16H8v-2h8v2zm0-4H8v-2h8v2zm-3-5V3.5L18.5 9H13z"/></svg>
                  Pedigrí FIFE
                </span>
              </div>

              <div class="breed-footer">
                <span class="footer-link">
                  Ver {breed.total} gatitos {breed.name}
                  <svg viewBox="0 0 24 24" width="18" height="18"><path d="M8.59 16.59L13.17 12 8.59 7.41 10 6l6 6-6 6z" fill="currentColor"/></svg>
                </span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <ContactPopup />
</BaseLayout>

<style>
  .breeds-section {
    display: block;
    font-family: var(--font-family, 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif);
    padding: 2.5rem 1.5rem 4rem;
    background: #F0F4F8;
  }

  .breeds-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .breeds-header {
    text-align: center;
    margin-bottom: 2rem;
  }

  .total-badge {
    display: inline-block;
    background: #1B2A4A;
    color: white;
    padding: 0.5rem 1.25rem;
    border-radius: 4px;
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.3px;
  }

  .breeds-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.75rem;
  }

  .breed-card {
    background: white;
    border-radius: 6px;
    overflow: hidden;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    border: 1px solid #e2e8f0;
  }

  .breed-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.14);
    border-color: #2E8B8B;
  }

  .breed-image {
    position: relative;
    height: 420px;
    overflow: hidden;
  }

  .breed-image {
    background: #e8edf2;
  }

  .breed-image img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    transition: transform 0.4s ease;
  }

  .breed-card:hover .breed-image img {
    transform: scale(1.06);
  }

  .image-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: rgba(27, 42, 74, 0.5);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .breed-card:hover .image-overlay {
    opacity: 1;
  }

  .overlay-cta {
    color: white;
    font-size: 1rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    padding: 0.6rem 1.5rem;
    border: 2px solid white;
    border-radius: 4px;
  }

  .breed-badge {
    position: absolute;
    top: 0.75rem;
    left: 0.75rem;
    background: #1B2A4A;
    color: white;
    padding: 0.35rem 0.75rem;
    border-radius: 3px;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.3px;
  }

  .breed-body {
    padding: 1.25rem 1.5rem 1.5rem;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .breed-title-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1rem;
  }

  .breed-name {
    font-size: 1.35rem;
    font-weight: 700;
    color: #1B2A4A;
    margin: 0;
  }

  .breed-price {
    font-size: 0.8rem;
    font-weight: 700;
    color: #2E8B8B;
    background: #F0F4F8;
    padding: 0.3rem 0.6rem;
    border-radius: 3px;
    white-space: nowrap;
  }

  .breed-stats {
    display: flex;
    align-items: center;
    gap: 0;
    padding: 0.75rem 0;
    border-top: 1px solid #E2E8F0;
    border-bottom: 1px solid #E2E8F0;
    margin-bottom: 1rem;
  }

  .stat {
    flex: 1;
    text-align: center;
  }

  .stat-number {
    display: block;
    font-size: 1.15rem;
    font-weight: 800;
    color: #1B2A4A;
    line-height: 1.2;
  }

  .stat-text {
    display: block;
    font-size: 0.65rem;
    color: #888;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    font-weight: 600;
  }

  .stat-divider {
    width: 1px;
    height: 30px;
    background: #E2E8F0;
  }

  .breed-description {
    font-size: 0.85rem;
    color: #555;
    line-height: 1.65;
    margin: 0 0 1rem;
    flex: 1;
  }

  .breed-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }

  .tag {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    background: #F0F4F8;
    color: #1B2A4A;
    padding: 0.3rem 0.6rem;
    border-radius: 3px;
    font-size: 0.7rem;
    font-weight: 600;
    border: 1px solid #e2e8f0;
  }

  .tag svg {
    color: #2E8B8B;
  }

  .breed-footer {
    padding-top: 1rem;
    border-top: 1px solid #E2E8F0;
  }

  .footer-link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    color: #2E8B8B;
    font-size: 0.85rem;
    font-weight: 700;
    transition: gap 0.3s ease, color 0.3s ease;
  }

  .breed-card:hover .footer-link {
    gap: 0.6rem;
    color: #1B2A4A;
  }

  @media (max-width: 900px) {
    .breeds-grid {
      grid-template-columns: 1fr;
      max-width: 600px;
      margin: 0 auto;
    }

    .breed-image {
      height: 420px;
    }
  }

  @media (max-width: 600px) {
    .breeds-section {
      padding: 2rem 1rem 3rem;
    }

    .breed-image {
      height: 340px;
    }

    .breed-body {
      padding: 1rem 1.25rem 1.25rem;
    }

    .breed-title-row {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
    }

    .breed-name {
      font-size: 1.2rem;
    }

    .breed-stats {
      padding: 0.6rem 0;
    }

    .stat-number {
      font-size: 1rem;
    }

    .breed-tags {
      gap: 0.4rem;
    }

    .tag {
      font-size: 0.65rem;
      padding: 0.25rem 0.5rem;
    }
  }
</style>
