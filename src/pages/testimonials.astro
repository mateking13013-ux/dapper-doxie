---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHeader from '../components/PageHeader.astro';
import TestimonialsPreview from '../components/TestimonialsPreview.astro';
---

<BaseLayout
  title="Testimonials | Dapper Doxie"
  description="Read what happy families have to say about their Dapper Doxie Dachshund puppies. Over 800 families served since 1995."
  keywords="Dachshund puppy reviews, Dapper Doxie testimonials, Dachshund breeder reviews, happy puppy families, puppy owner testimonials"
>
  <PageHeader
    title="Testimonials"
    subtitle="Hear from the happy families who welcomed a Dapper Doxie Dachshund into their home"
    breadcrumbs={[
      { label: 'Home', href: '/' },
      { label: 'Testimonials' }
    ]}
  />

  <TestimonialsPreview />
</BaseLayout>
